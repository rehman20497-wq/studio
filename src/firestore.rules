
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is signed in via the admin panel
    function isSignedIn() {
      return request.auth != null;
    }

    // Default read-only access for most collections
    match /{document=**} {
      allow read: if true;
      allow write: if false; // Default to no write access
    }
    
    // Rules for newsletter subscribers
    match /newsletter_subscribers/{subscriberId} {
      // Anyone can sign up for the newsletter
      allow create: if true;
      // Admins can read the list
      allow read: if isSignedIn();
      // Nobody else can update or delete
      allow update, delete: if false;
    }

    // Rules for the 'providers' collection
    match /providers/{providerId} {
      // Admins can do anything
      allow read, write: if isSignedIn();
      // Public can read published providers
      allow get: if resource.data.published == true;
      allow list: if request.query.where.size() > 0 && request.query.where[0][2] == true;
    }

    // Rules for the 'blog_posts' collection
    match /blog_posts/{postId} {
      // Public can read all blog posts
      allow read: if true;
      // Admins can write
      allow write: if isSignedIn();
    }
  }
}
