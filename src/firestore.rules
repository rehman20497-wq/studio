
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is an authenticated admin
    function isSignedIn() {
      return request.auth != null;
    }

    // Rules for the 'providers' collection
    // Public can read all provider data.
    // Only signed-in admins can write data.
    match /providers/{providerId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Rules for the 'blog_posts' collection
    // Public can read all blog post data.
    // Only signed-in admins can write data.
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Fallback for any other collections not explicitly defined
    // Public can read, only admins can write.
    match /{path=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
