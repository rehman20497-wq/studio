
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is an authenticated admin
    function isSignedIn() {
      return request.auth != null;
    }

    // Default rule: Allow public read access to all collections, 
    // but restrict all write operations to authenticated admins.
    match /{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
