
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is signed in via the admin panel
    function isSignedIn() {
      return request.auth != null;
    }

    // Rules for the 'providers' collection
    match /providers/{providerId} {
      // Admins can do anything
      allow read, write: if isSignedIn();

      // Public can only get a document if it is published
      allow get: if !isSignedIn() && resource.data.published == true;

      // Public can list documents only if they query for published ones
      allow list: if !isSignedIn() && request.query.where.size() > 0 && request.query.where[0][2] == true;
    }

    // Rules for the 'blog_posts' collection
    match /blog_posts/{postId} {
      // Public can read any blog post
      allow read: if true;
      // Admins can write
      allow write: if isSignedIn();
    }

    // Fallback for any other collections not explicitly defined
    match /{path=**} {
      allow read: if true; 
      allow write: if isSignedIn(); // Allow admin writes everywhere else
    }
  }
}
