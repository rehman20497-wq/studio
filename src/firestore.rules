
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is signed in via the admin panel
    function isSignedIn() {
      return request.auth != null;
    }

    // Default-deny all writes, and allow all reads.
    // Specific write rules are layered on top of this.
    match /{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
