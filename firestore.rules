
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default to read-only for all, and write-only for authenticated users.
    // This can be overridden by more specific rules below.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Rules for the 'providers' collection
    match /providers/{providerId} {
      // Public can read all published providers
      allow read: if resource.data.published == true;
       // Admins can write
      allow write: if request.auth != null;
    }

    // Rules for the 'blog_posts' collection
    match /blog_posts/{postId} {
      // Public can read all blog posts
      allow read: if true;
      // Admins can write
      allow write: if request.auth != null;
    }
    
    // Rules for newsletter subscribers
    match /newsletter_subscribers/{subscriberId} {
      // Anyone can sign up for the newsletter
      allow create: if true;
      // Admins can read and delete subscribers
      allow read, delete: if request.auth != null;
      // Nobody can update the list of subscribers
      allow update: if false;
    }

    // Rules for admin users and roles
    match /admin_users/{userId} {
        allow read, write: if request.auth != null;
    }

    match /admin_roles/{roleId} {
        allow read, write: if request.auth != null;
    }
  }
}

    