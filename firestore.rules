
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is signed in via the admin panel
    function isSignedIn() {
      return request.auth != null;
    }

    // Match all documents in all collections
    match /{path=**} {
      // Admins (signed-in users) can do anything.
      // This single rule grants them full read and write access everywhere.
      allow read, write: if isSignedIn();

      // Public (unauthenticated) users can only read data.
      // This grants get and list access to all collections for public viewers.
      allow get, list: if !isSignedIn();
    }
  }
}
