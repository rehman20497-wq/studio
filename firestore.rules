
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default to read-only for all, and write-only for authenticated users.
    // This can be overridden by more specific rules below.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Rules for the 'providers' collection
    match /providers/{providerId} {
      // Public can read all published providers
      allow read: if resource.data.published == true;
       // Admins can write
      allow write: if request.auth != null;
    }

    // Rules for the 'blog_posts' collection
    match /blog_posts/{postId} {
      // Public can read all blog posts
      allow read: if true;
      // Admins can write
      allow write: if request.auth != null;
    }
    
    // Rules for newsletter subscribers
    match /newsletter_subscribers/{subscriberId} {
      // Anyone can sign up for the newsletter
      allow create: if true;
      // Nobody can read, update or delete the list of subscribers
      allow read, update, delete: if false;
    }
  }
}

    