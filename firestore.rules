
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is signed in via the admin panel
    function isSignedIn() {
      return request.auth != null;
    }

    // Rules for the 'providers' collection
    match /providers/{providerId} {
      // Admins can do anything
      allow write: if isSignedIn();
      // Public can read all providers
      allow read: if true;
    }

    // Rules for the 'blog_posts' collection
    match /blog_posts/{postId} {
      // Admins can write
      allow write: if isSignedIn();
      // Public can read all blog posts
      allow read: if true;
    }

    // Fallback for any other collections not explicitly defined
    match /{path=**} {
      // Default to admin-only access for any other paths
      allow read, write: if isSignedIn();
    }
  }
}
