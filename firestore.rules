rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /blog_posts/{postId} {
      allow read, list, write: if true;
    }

    match /providers/{providerId} {
      allow read, list, write: if true;
    }

    match /{path=**} {
      allow read, list, write: if true;
    }
  }
}
