
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is an authenticated admin
    function isSignedIn() {
      return request.auth != null;
    }

    // Rules for the 'providers' collection
    // Allow public read access, but only admins can write.
    match /providers/{providerId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Rules for the 'blog_posts' collection
    // Allow public read access, but only admins can write.
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Rules for any other collection
    // By default, allow admin read/write, but deny public access.
    // This is more secure than a broad public read.
    match /{path=**} {
      allow read, write: if isSignedIn();
    }
  }
}
