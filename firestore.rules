
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default to denying all access unless explicitly allowed.
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow public read access to providers and blog posts.
    match /providers/{providerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
